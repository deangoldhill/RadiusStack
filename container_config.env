# === RADIUS FULLSTACK CONFIGURATION ===
# Change the ports below to bind the containers to different host ports.

# Nginx Web Frontend Port
WEB_UI_PORT=80

# Backend Node.js API Port
API_PORT=3000

# FreeRADIUS Ports
RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813

# Database Export Port (Change if you want to connect externally, e.g., using DataGrip/DBeaver)
DB_PORT=3306

# phpMyAdmin Port
PHPMYADMIN_PORT=8080
